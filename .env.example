# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=home

# LLM Provider — default is OpenRouter (works in HK, supports 100+ models)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# Optional: use different providers per component by setting these
# and updating api_key_env in config/config.yaml
# GROQ_API_KEY=gsk_your-groq-api-key
# GEMINI_API_KEY=your-gemini-api-key
# MISTRAL_API_KEY=your-mistral-api-key

# Threads (Meta Graph API)
THREADS_APP_ID=your_app_id
THREADS_APP_SECRET=your_app_secret
THREADS_ACCESS_TOKEN=your_long_lived_access_token
THREADS_USER_ID=your_user_id
